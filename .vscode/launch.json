{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "调试当前包 (Launch Package)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${fileDirname}"
    },
    {
      "name": "调试当前文件 (Debug Current File)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${file}"
    },
    {
      "name": "运行 1-1-point 示例",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/1-1-point"
    },
    {
      "name": "运行 1-2-error 示例",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/1-2-error"
    },
    {
      "name": "带参数运行",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${fileDirname}",
      "args": ["arg1", "arg2"]
    },
    {
      "name": "调试测试 (Test Current Function)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}"
    }
  ]
}
